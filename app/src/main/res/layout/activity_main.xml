<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS Spoof"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stato: fermo"
            android:textColor="#B71C1C"
            android:paddingBottom="12dp" />

        <!-- ================= POSIZIONE FISSA ================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Posizione fissa"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="8dp" />

        <EditText
            android:id="@+id/latInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitudine (es. 44.6469)"
            android:inputType="numberSigned|numberDecimal" />

        <EditText
            android:id="@+id/lngInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitudine (es. 10.9252)"
            android:inputType="numberSigned|numberDecimal" />

        <Button
            android:id="@+id/setFixedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Imposta posizione fissa" />

        <!-- ================= PERCORSO ================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Percorso (cammina da A a B)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Un punto per riga: lat,lng — metti almeno 2 punti (start e fine). Puoi aggiungere punti intermedi per seguire le vie."
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/waypointsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:gravity="top"
            android:hint="44.6400,10.9200&#10;44.6450,10.9250&#10;44.6469,10.9252"
            android:inputType="textMultiLine" />

        <EditText
            android:id="@+id/speedInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Velocita km/h (es. 5 = camminata)"
            android:text="5"
            android:inputType="numberDecimal" />

        <CheckBox
            android:id="@+id/loopCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ripeti in loop" />

        <Button
            android:id="@+id/startRouteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Avvia percorso" />

        <!-- ================= STOP ================= -->
        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STOP"
            android:layout_marginTop="24dp"
            android:backgroundTint="#B71C1C" />

        <Button
            android:id="@+id/devOptionsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apri Opzioni sviluppatore"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IMPORTANTE: in Opzioni sviluppatore, imposta questa app come 'App per posizioni fittizie / Select mock location app'. Senza quello non funziona."
            android:textSize="12sp"
            android:paddingTop="12dp" />

    </LinearLayout>
</ScrollView>
